# LLM Handbook MVP environment template
# Copy to .env for local run: cp .env.example .env

# --- Runtime environment ---
APP_ENV=dev
DATABASE_URL=postgresql+psycopg://llm:llm@db:5432/llm_handbook
JWT_SECRET_KEY=change-me-in-prod
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- Cookies / web security ---
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# --- Telegram auth integration (optional locally, required if Telegram login is used) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ID=

# --- Password/KDF policy ---
# Supported: scrypt | argon2id
PASSWORD_KDF_ALGORITHM=scrypt
PASSWORD_MIGRATE_ON_LOGIN=true
PASSWORD_LEGACY_ACCEPT=true

# scrypt params
PASSWORD_SCRYPT_N=16384
PASSWORD_SCRYPT_R=8
PASSWORD_SCRYPT_P=1
PASSWORD_SCRYPT_DKLEN=64
PASSWORD_SCRYPT_SALT_BYTES=16

# argon2id params
PASSWORD_ARGON2_TIME_COST=3
PASSWORD_ARGON2_MEMORY_COST_KIB=65536
PASSWORD_ARGON2_PARALLELISM=2
PASSWORD_ARGON2_HASH_LEN=32
PASSWORD_ARGON2_SALT_BYTES=16

# --- Content ingestion ---
CONTENT_VALIDATE_ON_STARTUP=true

# --- LLM adapter policy ---
LLM_TIMEOUT_SECONDS=8
LLM_FALLBACK_LECTURE=Сервис AI временно недоступен. Попробуй ещё раз через минуту.
LLM_FALLBACK_CONSULTANT=Консультант временно недоступен. Попробуй повторить запрос позже.
RAG_TOP_K=3

# --- docker-compose postgres defaults ---
POSTGRES_DB=llm_handbook
POSTGRES_USER=llm
POSTGRES_PASSWORD=llm

# --- Optional test smoke (not used by app runtime) ---
# TEST_POSTGRES_DATABASE_URL=postgresql+psycopg://llm:llm@localhost:5432/llm_handbook
